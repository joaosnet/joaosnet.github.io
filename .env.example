# GitHub Token para acessar repositórios privados e evitar rate limits
# Obtenha em: https://github.com/settings/tokens
# Permissões necessárias: repo (para repos privados)
PRIVATE_REPOS_TOKEN=

# Token legado (ainda funciona, mas PRIVATE_REPOS_TOKEN é preferido)
GITHUB_TOKEN=

# URL do Google Apps Script para rastreamento de visitantes
# Deixe vazio se não quiser usar o rastreamento
GOOGLE_APPS_SCRIPT_URL=

# ID da planilha Google Sheets (para backend)
# Obtenha na URL da planilha: https://docs.google.com/spreadsheets/d/[ID_AQUI]/edit
GOOGLE_SHEET_ID=

# Formspree ID para formulário de contato
# Obtenha em: https://formspree.io/
FORMSPREE_ENDPOINT=
